---
import { ClientRouter } from 'astro:transitions'

interface Props { title:string }
const { title } = Astro.props

const site = {
  title: 'InvisyArcticFox\'s Blog',
  user: 'InvisyArcticFox',
  desc: 'For when I just wanna write about stuff!',
  img: 'https://cdn.itaf.uk/img/blogbanner.png'
}

const htmlTitle = `ItAF - P: ${title}`
---

<html lang='en'>
<head>
  <ClientRouter />
      
  <meta charset='utf-8'>
	<link rel='icon' type='image/svg+xml' href='https://itaf.uk/favicon.svg'>
	<link rel='shortcut icon' href='https://itaf.uk/favicon.ico'>
	<link rel='icon' type='image/png' href='https://itaf.uk/favicons/favicon-96x96.png' sizes='96x96'>
	<link rel='apple-touch-icon' sizes='180x180' href='https://itaf.uk/favicons/apple-touch-icon.png'>
	<meta name='apple-mobile-web-app-title' content={'InvisyArcticFox\'s Blog'}>
	<link rel='manifest' href='/site.webmanifest'>

	<meta name='viewport' content='width=device-width, initial-scale=1.0'>
	<meta name='generator' content={Astro.generator}>
	<title>{htmlTitle}</title>
	<link rel='stylesheet' href='https://itaf.uk/master.css'>
	<link rel='canonical' href={Astro.url}>
	<link rel='alternate' href={`https://blog.invisyarcticfox.uk` + Astro.url.pathname}>
	<link rel='sitemap' type='application/xml' href={new URL('/sitemap-index.xml', Astro.site)}>
  <link rel='alternate' type='application/rss+xml' href={new URL('/rss.xml', Astro.site)}>

  <meta name='title' content={htmlTitle}>
	<meta name='description' content={site.desc}>
	<meta name='keywords' content='invisyarcticfox, invisy arcticfox, invisy arctic fox'>
  <meta name='image' content={site.img}>
	<meta name='author' content={site.user}>
	<meta name='theme-color' content='#a6e3a1'>
	<meta name='robots' content='index, follow'>
	<meta http-equiv='Content-Type' content='text/html; charset=utf-8'>
	<meta name='language' content='English'>
	<meta name='revisit-after' content='30 days'>
  
  <meta property='og:type' content={'website'}>
  <meta property='og:title' content={htmlTitle}>
  <meta property='og:description' content={site.desc}>
  <meta property='og:url' content={Astro.url}>
  <meta property='og:image' content={site.img}>
  <meta property='og:image:width' content='1280'>
  <meta property='og:image:height' content='720'>

  <meta name='twitter:card' content='summary_large_image'>
  <meta name='twitter:site' content={`@${site.user}`}>
  <meta name='twitter:creator' content={`@${site.user}`}>
  <meta name='twitter:title' content={htmlTitle}>
  <meta name='twitter:description' content={site.desc}>
  <meta name='twitter:image' content={site.img}>
</head>
<body>
  <main>
    <slot />
  </main>
</body>
</html>